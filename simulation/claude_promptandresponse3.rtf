\f1\fs26 \cf4 \cb5 \strokec4 \
\
\pard\pardeftab720\partightenfactor0
\cf7 \strokec7 Linearize rotational dynamics around equilibrium (theta=0, theta_dot=0, gimbal=0).\
The 2\'d72 system matrix A for state [theta, theta_dot]:\
\pard\pardeftab720\partightenfactor0

\f0\fs28 \cf2 \cb3 \strokec2 # From Newton-Euler rotational equation:\
# theta_ddot = (F_T * MOMENT_ARM * delta - AERO_DAMP_COEFF * q_dyn * A_cs * CP_OFFSET * theta_dot) / MOI\
# Linearized: theta_ddot = (F_T * MOMENT_ARM / MOI) * delta - (C_damp / MOI) * theta_dot\
# With PD control: delta = -KP * theta - KD * theta_dot\
# Substitute: \
# theta_dot  = theta_dot\
# theta_ddot = -(F_T * MOMENT_ARM * KP / MOI) * theta \
#              - (F_T * MOMENT_ARM * KD / MOI + C_damp_effective / MOI) * theta_dot\
\
a12 = 1.0\
a21 = -(thrust * MOMENT_ARM * KP) / MOI\
a22 = -(thrust * MOMENT_ARM * KD + aero_damp_effective) / MOI\
# where aero_damp_effective = AERO_DAMP_COEFF * q_dyn * A_cs * CP_OFFSET at operating point\
\
A = [[0, a12], [a21, a22]]\
eigenvalues = np.linalg.eigvals(A)\cb1 \
\pard\pardeftab720\qr\partightenfactor0

