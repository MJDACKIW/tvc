\cf7 \strokec7 __init__(self, kp=KP, ki=KI, kd=KD):\
    self.kp, self.ki, self.kd = kp, ki, kd\
    self.integral = 0.0\
    self.prev_error = 0.0\
    self.prev_output = 0.0\
\
update(self, error_deg, dt):\
    p = self.kp * error_deg\
    self.integral += self.ki * error_deg * dt\
    self.integral = clip(self.integral, -GIMBAL_LIMIT, GIMBAL_LIMIT)  # anti-windup\
    d = self.kd * (error_deg - self.prev_error) / dt\
    raw = p + self.integral + d\
    \
    # Servo rate limiting\
    max_delta = SERVO_RATE_LIM * dt\
    output = clip(raw, self.prev_output - max_delta, self.prev_output + max_delta)\
    \
    # Hard stop\
    output = clip(output, -GIMBAL_LIMIT, GIMBAL_LIMIT)\
    \
    self.prev_error = error_deg\
    self.prev_output = output\
    return output\
\
reset(self):\
    Re-initializes all state to 0\
\pard\pardeftab720\partightenfactor0

