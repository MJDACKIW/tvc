\cf7 \strokec7 __init__(self):\
    self.state = [0.0, 0.0]   # [angle_deg, gyro_bias_dps]\
    self.P = [[1,0],[0,1]]\
    self.rng = np.random.default_rng()  # for noise injection during simulation\
\
update(self, gyro_rate_dps, accel_angle_deg, dt):\
    # Standard 2-state discrete Kalman\
    # F = [[1, -dt], [0, 1]]\
    # B = [dt, 0]\
    # H = [1, 0]\
    # Q = diag([Q_ANGLE, Q_RATE])\
    # R = R_MEASURE\
    # Predict: state_pred = F @ state + B * gyro_rate_dps\
    # P_pred = F @ P @ F.T + Q\
    # Update: y = accel_angle_deg - H @ state_pred\
    # S = H @ P_pred @ H.T + R\
    # K = P_pred @ H.T / S\
    # state = state_pred + K * y\
    # P = (I - K @ H) @ P_pred\
    Returns (estimated_angle_deg, estimated_rate_dps)\
\
reset(self, angle=0.0):\
    Re-initializes state and P\
\pard\pardeftab720\partightenfactor0

