\cf7 \strokec7 control_step_counter += 1\
physics_steps_per_control = round(1.0 / (CONTROL_HZ * DT_SIM))  # = 7 at 150Hz, 1ms\
\
# 1. Advance dynamics\
theta, theta_dot, psi, psi_dot = dynamics.step(t, gimbal_pitch, gimbal_yaw,\
    wind_torque_pitch=disturbance_torque_pitch, thrust_scale=thrust_scale)\
\
# 2. Generate sensor readings (add noise to true state)\
gyro_pitch_reading = theta_dot + rng.normal(0, GYRO_NOISE_STD) + gyro_bias\
accel_pitch_reading = theta + rng.normal(0, ACCEL_NOISE_STD)\
# same for yaw\
# Post-burnout: accumulate GYRO_DRIFT_RATE * DT_SIM to gyro readings\
\
# 3. Kalman update\
k_pitch_angle, k_pitch_rate = kalman_pitch.update(gyro_pitch_reading, accel_pitch_reading, DT_SIM)\
# same for yaw\
\
# 4. FlightComputer update\
accel_g = motor.get_thrust(t, thrust_scale) / (ROCKET_MASS * 9.81)\
flight_computer.update(t, accel_g)\
\
# 5. Control update (every physics_steps_per_control steps)\
if control_step_counter >= physics_steps_per_control:\
    control_step_counter = 0\
    if flight_computer.control_active and not open_loop:\
        gimbal_pitch = pid_pitch.update(-k_pitch_angle, DT_SIM * physics_steps_per_control)\
        gimbal_yaw   = pid_yaw.update(-k_psi_angle,    DT_SIM * physics_steps_per_control)\
    else:\
        gimbal_pitch = 0.0\
        gimbal_yaw   = 0.0\
\
