\cf8 \strokec8 if (!control_flag) return;\
control_flag = false;\
\
uint32_t now_ms = millis();\
float dt = LOOP_INTERVAL_US / 1e6f;  // 0.006667 s\
\
// 1. Read IMU\
mpu_read();\
\
// 2. Kalman update\
float est_pitch = kalman_pitch.update(gyro_pitch_dps, accel_pitch_deg, dt);\
float est_yaw   = kalman_yaw.update(gyro_yaw_dps,   accel_yaw_deg,   dt);\
\
// 3. State machine\
switch(flight_state) \{\
  case PAD_IDLE:\
    if (accel_mag_g > LAUNCH_ACCEL_G) \{\
      flight_state = POWERED_FLIGHT;\
      launch_time_ms = now_ms;\
      Serial.println("LAUNCH DETECTED");\
    \}\
    break;\
\
  case POWERED_FLIGHT:\
    if (accel_mag_g < BURNOUT_ACCEL_G) \{\
      burnout_sample_count++;\
      if (burnout_sample_count >= BURNOUT_SAMPLES) \{\
        flight_state = BURNOUT;\
        burnout_time_ms = now_ms;\
        gimbal_pitch_deg = 0;\
        gimbal_yaw_deg   = 0;\
        write_servo_deg(servo_pitch, 0);\
        write_servo_deg(servo_yaw,   0);\
        Serial.print("BURNOUT at ");\
        Serial.print((now_ms - launch_time_ms) / 1000.0f, 3);\
        Serial.print("s  |  IAE pitch=");\
        Serial.print(iae_pitch, 4);\
        Serial.print(" yaw=");\
        Serial.println(iae_yaw, 4);\
      \}\
    \} else \{\
      burnout_sample_count = 0;\
    \}\
    \
    // Safety timeout\
    if ((now_ms - launch_time_ms) > (uint32_t)(BURN_TIME_MAX_S * 1000)) \{\
      flight_state = BURNOUT;\
    \}\
    break;\
\
  case BURNOUT:\
    // Do nothing \'97 log only\
    break;\
\}\
\
// 4. PID control (only during powered flight)\
if (flight_state == POWERED_FLIGHT) \{\
  gimbal_pitch_deg = pid_pitch.update(-est_pitch, dt);\
  gimbal_yaw_deg   = pid_yaw.update(-est_yaw,   dt);\
  \
  write_servo_deg(servo_pitch, gimbal_pitch_deg);\
  write_servo_deg(servo_yaw,   gimbal_yaw_deg);\
  \
  // Accumulate IAE\
  iae_pitch += fabsf(est_pitch) * dt;\
  iae_yaw   += fabsf(est_yaw)   * dt;\
\}\
\
// 5. Log to SD\
if (sd_ok) \{\
  sd_log(now_ms);\
\}\
\pard\pardeftab720\partightenfactor0

\f0\fs28 \cf2 \cb3 \strokec2 SD flush management\
In loop(), after control logic: if row_count % 50 == 0, call log_file.flush(). This prevents data loss without blocking the control path on every write.\
At program end (or never \'97 rocket doesn't land in a recoverable way on test stand):\
On BURNOUT detection, flush and close file immediately after printing final IAE.\
